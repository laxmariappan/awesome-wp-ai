---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Awesome WP AI — Curated WordPress AI Tools, Plugins & Resources',
  description = 'A curated list of the best AI-powered plugins, tools, themes, frameworks and resources for WordPress.',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Dark-first: default to dark, respect explicit light preference -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (stored === 'light' || (!stored && prefersLight)) {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-surface-900 text-gray-900 dark:text-slate-100 font-sans antialiased transition-colors duration-300">
    <slot />
  </body>
</html>

<style is:global>
  /* ── Fonts ───────────────────────────────────────────────────────── */
  :root { font-feature-settings: 'cv02','cv03','cv04','cv11'; }

  /* ── Scrollbar ───────────────────────────────────────────────────── */
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  /* ── Line clamp ──────────────────────────────────────────────────── */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Gradient text shimmer ───────────────────────────────────────── */
  .text-shimmer {
    background: linear-gradient(
      90deg,
      #60a5fa 0%,
      #a5f3fc 25%,
      #e0f2fe 45%,
      #bae6fd 55%,
      #a5f3fc 75%,
      #60a5fa 100%
    );
    background-size: 250% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3.5s linear infinite;
  }

  /* ── Gradient border card ────────────────────────────────────────── */
  /* Dark mode (default) */
  .glow-card {
    background:
      linear-gradient(#080f1e, #080f1e) padding-box,
      linear-gradient(135deg, rgba(59,130,246,0.14) 0%, rgba(6,182,212,0.08) 100%) border-box;
    border: 1px solid transparent;
    transition:
      transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.22s ease,
      background 0.22s ease;
  }
  .glow-card:hover {
    background:
      linear-gradient(#0a1628, #0a1628) padding-box,
      linear-gradient(135deg, rgba(59,130,246,0.55) 0%, rgba(6,182,212,0.45) 100%) border-box;
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(59,130,246,0.06),
      0 6px 28px rgba(59,130,246,0.18),
      0 20px 48px rgba(0,0,0,0.45);
  }
  /* Light mode override */
  html:not(.dark) .glow-card {
    background:
      linear-gradient(#ffffff, #ffffff) padding-box,
      linear-gradient(135deg, rgba(59,130,246,0.16) 0%, rgba(6,182,212,0.1) 100%) border-box;
  }
  html:not(.dark) .glow-card:hover {
    background:
      linear-gradient(#f0f7ff, #f0f7ff) padding-box,
      linear-gradient(135deg, rgba(59,130,246,0.5) 0%, rgba(6,182,212,0.38) 100%) border-box;
    transform: translateY(-3px);
    box-shadow:
      0 6px 24px rgba(59,130,246,0.14),
      0 2px 8px rgba(0,0,0,0.06);
  }

  /* ── Gradient CTA button with shimmer sweep ──────────────────────── */
  .btn-gradient {
    background: linear-gradient(135deg, #2563eb 0%, #0891b2 100%);
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }
  .btn-gradient::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.18) 50%, transparent 100%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .btn-gradient:hover { box-shadow: 0 0 24px rgba(37,99,235,0.45); }
  .btn-gradient:hover::after { transform: translateX(100%); }
  .btn-gradient:active { transform: scale(0.97); }

  /* ── Ghost button ────────────────────────────────────────────────── */
  .btn-ghost {
    border: 1px solid rgba(59,130,246,0.3);
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-ghost:hover {
    border-color: rgba(59,130,246,0.6);
    background: rgba(59,130,246,0.06);
    box-shadow: 0 0 16px rgba(59,130,246,0.15);
  }

  /* ── Search input glow ───────────────────────────────────────────── */
  .glow-input {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .glow-input:focus {
    outline: none;
    border-color: rgba(59,130,246,0.6);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12), 0 0 16px rgba(59,130,246,0.1);
  }

  /* ── Sidebar item ────────────────────────────────────────────────── */
  .sidebar-item {
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .sidebar-item:hover { transform: translateX(3px); }

  /* ── Featured top bar ────────────────────────────────────────────── */
  .featured-bar {
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #06b6d4);
    border-radius: 1rem 1rem 0 0;
  }

  /* ── Noise texture overlay ───────────────────────────────────────── */
  .noise::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    border-radius: inherit;
    pointer-events: none;
    opacity: 0.4;
  }

  /* ── Selection ───────────────────────────────────────────────────── */
  ::selection { background: rgba(59,130,246,0.25); color: inherit; }
</style>
