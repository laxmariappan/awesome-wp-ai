---
const base = import.meta.env.BASE_URL;
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-white/[0.06] bg-surface-900/80 backdrop-blur-xl transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-15 items-center justify-between gap-4 py-3.5">

      <!-- Logo -->
      <a href={base} class="group flex items-center gap-2.5 flex-shrink-0">
        <!-- Icon with gradient + glow -->
        <div class="relative w-8 h-8 flex-shrink-0">
          <div class="absolute inset-0 rounded-lg bg-gradient-to-br from-brand-500 to-cyan-500 opacity-20 blur-md group-hover:opacity-40 transition-opacity duration-300"></div>
          <div class="relative w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-cyan-500 flex items-center justify-center shadow-glow-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <!-- Wordmark -->
        <span class="font-bold text-sm text-white/80 group-hover:text-white transition-colors duration-200 font-mono tracking-tight">
          awesome<span class="text-shimmer">-wp-ai</span>
        </span>
      </a>

      <!-- Right side actions -->
      <div class="flex items-center gap-2.5">

        <!-- GitHub stars badge -->
        <a
          href="https://github.com/laxmariappan/awesome-wp-ai"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-slate-400 hover:text-white border border-white/[0.08] hover:border-white/20 bg-white/[0.04] hover:bg-white/[0.08] transition-all duration-200"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="flex-shrink-0">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>

        <!-- Submit a tool -->
        <a
          href="https://github.com/laxmariappan/awesome-wp-ai/blob/main/CONTRIBUTING.md"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-xs font-semibold btn-gradient text-white"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Submit a tool
        </a>

        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          aria-label="Toggle theme"
          class="w-8 h-8 flex items-center justify-center rounded-lg border border-white/[0.08] hover:border-brand-500/50 bg-white/[0.04] hover:bg-brand-500/10 text-slate-400 hover:text-brand-400 transition-all duration-200"
        >
          <svg id="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden dark:block">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg id="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="block dark:hidden">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  // Scroll shadow
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-[0_1px_0_rgba(255,255,255,0.06)]');
    } else {
      header?.classList.remove('shadow-[0_1px_0_rgba(255,255,255,0.06)]');
    }
  }, { passive: true });

  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
